# ============================================================
# Supabase — https://app.supabase.com → Settings → Database
# ============================================================

# Supabase JS client (used for auth / storage / realtime)
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<your-anon-key>"

# Prisma — PostgreSQL connection via Supabase connection pooler (port 6543)
DATABASE_URL="postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:6543/postgres"

# Prisma — direct connection for migrations (port 5432, bypasses pooler)
DIRECT_URL="postgresql://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:5432/postgres"
